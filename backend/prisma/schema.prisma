generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoGasto {
  Fixo
  Variavel
}

enum TipoPeriodo {
  Semanal
  Quinzenal
  Mensal
  Anual
}

enum TipoPatrimonio {
  Imovel
  Veiculo
  Investimento
  Equipamento
  Outros
}

model Familia {
  id          Int           @id @default(autoincrement())
  nome        String

  usuarios    Usuario[]
  membros     Membro[]
  patrimonios Patrimonio[]

  @@map("familia")
}

model Usuario {
  id         Int      @id @default(autoincrement())
  idFamilia  Int      @unique
  email      String   @unique
  senha      String

  familia    Familia  @relation(fields: [idFamilia], references: [id])
  membros    Membro[]

  @@map("usuario")
}

model Membro {
  id          Int         @id @default(autoincrement())
  idFamilia   Int
  idUsuario   Int
  nome        String

  familia      Familia     @relation(fields: [idFamilia], references: [id])
  usuario      Usuario     @relation(fields: [idUsuario], references: [id])

  despesas     Despesa[]
  salarios     Salario[]
  patrimonios  Patrimonio[]

  @@map("membro")
}

model Categoria {
  id         Int        @id @default(autoincrement())
  nome       String

  despesas   Despesa[]

  @@map("categoria")
}

model Despesa {
  id                Int            @id @default(autoincrement())
  idMembro          Int
  idCategoria       Int

  nome              String
  valor             Decimal        @db.Decimal(10, 2)
  data              DateTime       @db.Date

  tipo              TipoGasto
  periodo           TipoPeriodo?

  parcelasPagas     Int?
  totalParcelas     Int?

  membro            Membro         @relation(fields: [idMembro], references: [id])
  categoria         Categoria      @relation(fields: [idCategoria], references: [id])

  @@map("despesa")
}

model Salario {
  id               Int        @id @default(autoincrement())
  idMembro         Int

  salarioBruto     Decimal    @db.Decimal(10, 2)
  mesReferencia    DateTime   @db.Date

  membro           Membro     @relation(fields: [idMembro], references: [id])

  @@map("salario")
}

model Patrimonio {
  id            Int               @id @default(autoincrement())
  idFamilia     Int
  idMembro      Int?

  tipo          TipoPatrimonio

  nome          String
  valor         Decimal           @db.Decimal(15, 2)

  familia       Familia           @relation(fields: [idFamilia], references: [id])
  membro        Membro?           @relation(fields: [idMembro], references: [id])

  @@map("patrimonio")
}